# ─────────────────────────────────────────────────────────────────────────────
# CostGuard — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production          # development | production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=CHANGE-ME-USE-openssl-rand-hex-32

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501,https://your-frontend.up.railway.app

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# At least one required for Live Mode or /proxy endpoint.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk-...
XAI_API_KEY=xai-...
GEMINI_API_KEY=AIza...

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_MAX_ROWS=500
EVAL_SAMPLE_SEED=42
EVAL_TIMEOUT_SECONDS=60
EVAL_CONCURRENCY=3

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
UPLOAD_DIR=/tmp/costguard

# ── Observability ─────────────────────────────────────────────────────────────
# Use a persistent path — mount a volume in Docker so this survives restarts.
COSTGUARD_DB_PATH=/data/costguard_history.db

# ── Alerting ─────────────────────────────────────────────────────────────────
# Slack (optional)
SLACK_WEBHOOK_URL=

# Generic webhook — receives JSON alert payloads (PagerDuty, OpsGenie, etc.)
COSTGUARD_ALERT_WEBHOOK_URL=

# Alert thresholds
VALIDITY_ALERT_THRESHOLD=0.25       # Fire alert if validity drops below this
COST_SPIKE_MULTIPLIER=3.0           # Fire alert if cost is N× above rolling avg
FAILURE_RATE_THRESHOLD=0.20         # Fire alert if >20% of recent calls fail
CONSECUTIVE_LOW_VALIDITY=3          # Fire alert after N consecutive low-validity responses
ALERT_COOLDOWN_SECONDS=300          # Minimum seconds between same-type alerts

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_EVALUATE_RPM=5           # Max /evaluate requests per IP per minute
RATE_LIMIT_PROXY_RPM=60             # Max /proxy requests per IP per minute
RATE_LIMIT_DEFAULT_RPM=120          # Max other requests per IP per minute

# ── Monitoring (optional Prometheus + Grafana) ────────────────────────────────
# Start with: docker compose --profile monitoring up
GRAFANA_PASSWORD=costguard

# ── OpenTelemetry (optional — leave empty to disable) ─────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=        # e.g. http://jaeger:4317 or your OTLP collector
OTEL_SERVICE_NAME=costguard
