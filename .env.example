# ─────────────────────────────────────────────────────────────────────────────
# CostGuard — Environment Variables
# Copy this file to .env and fill in your values.
# Keys marked [REQUIRED] need at least ONE provider set for live evaluation.
# Keys marked [OPTIONAL] unlock additional providers in the comparison chart.
# Models without a key run in deterministic simulation mode (still shown).
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production          # development | production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-production

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501,https://your-frontend.up.railway.app

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Providers supported by RealDataAgentBench (used as evaluation engine)

# [REQUIRED] At least one of the following:
ANTHROPIC_API_KEY=sk-ant-...    # Claude Sonnet 4.6, Opus 4.6, Haiku 4.5
OPENAI_API_KEY=sk-...           # GPT-5, GPT-4.1, GPT-4o, GPT-4o-mini

# [OPTIONAL] Additional providers for broader comparison:
GROQ_API_KEY=gsk-...            # Llama 3.3-70B, Mixtral 8x7B (ultra-cheap, fast)
XAI_API_KEY=xai-...             # Grok-3, Grok-3-mini, Grok-3-fast
GEMINI_API_KEY=...              # Gemini 2.5 Pro/Flash (cheapest per token)

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_MAX_ROWS=500               # Max rows sampled per evaluation run
EVAL_SAMPLE_SEED=42             # Reproducibility seed
EVAL_TIMEOUT_SECONDS=60         # Max seconds per model evaluation
EVAL_CONCURRENCY=3              # Parallel model evaluations

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50                # Maximum file upload size in MB
UPLOAD_DIR=/tmp/costguard       # Temp storage for uploaded files

# ── Observability (Layer 4) ───────────────────────────────────────────────────
COSTGUARD_DB_PATH=/tmp/costguard_history.db  # SQLite file for eval history & drift logs
SLACK_WEBHOOK_URL=                           # Optional: Slack Incoming Webhook URL for drift alerts
                                             # Leave empty to disable alerts
                                             # Example: https://hooks.slack.com/services/T.../B.../...
