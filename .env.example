# ─────────────────────────────────────────────────────────────────────────────
# CostGuard — Environment Variables
# Copy this file to .env and fill in your values.
# Keys marked [REQUIRED] must be set for the app to function.
# Keys marked [OPTIONAL] enable additional providers.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production          # development | production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-production   # Used for internal signing

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501,https://your-frontend.up.railway.app

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000   # URL Streamlit calls for the backend

# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# [REQUIRED] At least one provider key must be set.

OPENAI_API_KEY=sk-...           # OpenAI (GPT-4o, GPT-4o-mini, GPT-3.5-turbo)
ANTHROPIC_API_KEY=sk-ant-...    # Anthropic (Claude 3.5, Claude 3 Haiku)

# [OPTIONAL] Additional providers
GOOGLE_API_KEY=                 # Google (Gemini 1.5 Pro, Flash)
GROQ_API_KEY=                   # Groq (Llama-3, Mixtral — ultra-cheap)
TOGETHER_API_KEY=               # Together AI (open-source models)

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_MAX_ROWS=500               # Max rows sampled per evaluation run
EVAL_SAMPLE_SEED=42             # Reproducibility seed
EVAL_TIMEOUT_SECONDS=60         # Max seconds per model evaluation
EVAL_CONCURRENCY=3              # Parallel model evaluations

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50                # Maximum file upload size in MB
UPLOAD_DIR=/tmp/costguard       # Temp storage for uploaded files
